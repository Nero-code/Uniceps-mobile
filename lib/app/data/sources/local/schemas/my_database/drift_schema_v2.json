      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"t_sessions\" (\"ts_id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"day_id\" INTEGER NOT NULL, \"day_name\" TEXT NOT NULL, \"started_at\" TEXT NOT NULL, \"finished_at\" TEXT NULL, \"progress\" REAL NOT NULL DEFAULT 0.0, \"api_id\" INTEGER NULL, \"version\" INTEGER NOT NULL DEFAULT 0, \"is_synced\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_synced\" IN (0, 1)));"
        }
      ]
    },
