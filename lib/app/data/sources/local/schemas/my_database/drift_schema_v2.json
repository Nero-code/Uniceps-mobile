        }
      ]
    },
    {
      "name": "routines",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"routines\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"api_id\" INTEGER NULL, \"version\" INTEGER NOT NULL, \"name\" TEXT NOT NULL, \"description\" TEXT NULL, \"is_current\" INTEGER NOT NULL CHECK (\"is_current\" IN (0, 1)), \"is_synced\" INTEGER NOT NULL CHECK (\"is_synced\" IN (0, 1)), \"created_at\" TEXT NOT NULL DEFAULT (CURRENT_TIMESTAMP), \"updated_at\" TEXT NOT NULL DEFAULT (CURRENT_TIMESTAMP));"
        }
      ]
    },
    {
      "name": "days_group",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"days_group\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"api_id\" INTEGER NULL, \"index\" INTEGER NOT NULL, \"version\" INTEGER NOT NULL, \"day_name\" TEXT NOT NULL, \"is_synced\" INTEGER NOT NULL CHECK (\"is_synced\" IN (0, 1)), \"routine_id\" INTEGER NOT NULL REFERENCES routines (id) ON UPDATE CASCADE ON DELETE CASCADE);"
        }
      ]
    },
    {
      "name": "exercises",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"exercises\" (\"api_id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"muscle_group_code\" TEXT NOT NULL, \"muscle_group_name\" TEXT NOT NULL, \"muscle_head_code\" TEXT NOT NULL, \"muscle_head_name\" TEXT NOT NULL, \"aux_muscle1\" TEXT NULL, \"aux_muscle2\" TEXT NULL, \"aux_muscle3\" TEXT NULL, \"laterals\" TEXT NOT NULL, \"description\" TEXT NULL, \"tool_code\" TEXT NOT NULL, \"tool_name\" TEXT NOT NULL, \"timestamp\" TEXT NOT NULL, PRIMARY KEY (\"api_id\"));"
        }
      ]
    },
    {
      "name": "routine_items",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"routine_items\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"api_id\" INTEGER NULL, \"index\" INTEGER NOT NULL, \"notes\" TEXT NULL, \"version\" INTEGER NOT NULL, \"is_synced\" INTEGER NOT NULL CHECK (\"is_synced\" IN (0, 1)), \"exercise_id\" TEXT NOT NULL REFERENCES exercises (api_id) ON UPDATE CASCADE ON DELETE CASCADE, \"day_id\" INTEGER NOT NULL REFERENCES days_group (id) ON UPDATE CASCADE ON DELETE CASCADE);"
        }
      ]
    },
    {
