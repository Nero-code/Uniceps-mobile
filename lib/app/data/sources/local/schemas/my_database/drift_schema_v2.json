      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"routine_sets\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"api_id\" INTEGER NULL, \"round_index\" INTEGER NOT NULL, \"reps_count\" INTEGER NOT NULL, \"version\" INTEGER NOT NULL, \"is_synced\" INTEGER NOT NULL CHECK (\"is_synced\" IN (0, 1)), \"routine_item_id\" INTEGER NOT NULL REFERENCES routine_items (id) ON UPDATE CASCADE ON DELETE CASCADE);"
        }
      ]
    },
